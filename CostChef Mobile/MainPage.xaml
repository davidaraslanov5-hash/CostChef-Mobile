<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CostChef_Mobile.MainPage"
             BackgroundColor="{Binding BackgroundColor}">

    <ScrollView>
        <VerticalStackLayout 
            HorizontalOptions="Center"
            Padding="30,0"
            Spacing="25">

            <VerticalStackLayout BackgroundColor="{Binding InteractColor}" Padding="40">
                <Entry
                TextColor="{Binding TextColor}"
                PlaceholderColor="Gray"
                Placeholder="Введите название ингредиента"
                Text="{Binding Name, Mode=TwoWay}"
                ></Entry>

                <Entry
                TextColor="{Binding TextColor}"
                PlaceholderColor="Gray"
                Placeholder="Введите размер упаковки"
                Text="{Binding PackageSize, Mode=TwoWay}"
                ></Entry>
                
                <Entry
                TextColor="{Binding TextColor}"
                PlaceholderColor="Gray"
                Placeholder="Введите стоимость ингредиента"
                Text="{Binding Price, Mode=TwoWay}"
                ></Entry>
                
                <Entry
                TextColor="{Binding TextColor}"
                PlaceholderColor="Gray"
                Placeholder="Введите количество использованного ингредиента"
                Text="{Binding UsedAmount, Mode=TwoWay}"
                ></Entry>
            </VerticalStackLayout>
            
            <Button
                BackgroundColor="DeepPink"
                TextColor="{Binding TextColor}"
                Text="Рассчитать себестоимость"
                Command="{Binding CalculateCostCommand}"
                HorizontalOptions="Fill" />

            <Label 
                IsVisible="{Binding IsVisibleTotalCost}"
                HorizontalOptions="Center"
                TextColor="{Binding TextColor}"
                Text="{Binding TotalCost, StringFormat='Итоговая цена: {0:0.00} ₽'}"
                ></Label>
            <CollectionView ItemsSource="{Binding Ingredients}" BackgroundColor="{Binding InteractColor}"  WidthRequest="320">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                              Margin="5"
                              Padding="10"
                              StrokeThickness="1">
                            <HorizontalStackLayout>
                                <Label Text="{Binding Name}"  
                                 TextColor="{Binding TextColor}"
                                 Padding="10"
                                 FontSize="15"
                                 FontAttributes="Bold"
                                 HorizontalOptions="Start"
                                 />
                                <Label Text="{Binding UsedAmount}"
                                 TextColor="{Binding TextColor}"
                                 Padding="10"
                                 FontSize="15"
                                 HorizontalOptions="Start"/>

                                <Label Text="{Binding Cost, StringFormat='Цена: {0:0.00} ₽'}"
                                 TextColor="{Binding TextColor}"
                                 Padding="10"
                                 FontSize="15"
                                 HorizontalOptions="Start"/>
                                
                                <Button Text="Удалить"
                                        BackgroundColor="Red"
                                        TextColor="White"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteCommand}"
                                        CommandParameter="{Binding}"
                                        HorizontalOptions="End"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>

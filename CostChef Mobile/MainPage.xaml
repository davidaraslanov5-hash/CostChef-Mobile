<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CostChef_Mobile.MainPage">

    <ScrollView>
        <VerticalStackLayout
            HorizontalOptions="Center"
            Padding="30,0"
            Spacing="25">

            <Entry
                Placeholder="Введите название ингредиента"
                Text="{Binding Name, Mode=TwoWay}"
                ></Entry>

            <Entry
                Placeholder="Введите размер упаковки"
                Text="{Binding PackageSize, Mode=TwoWay}"
                ></Entry>
            <Entry
                Placeholder="Введите стоимость ингредиента"
                Text="{Binding Price, Mode=TwoWay}"
                ></Entry>
            <Entry
                Placeholder="Введите количество использованного ингредиента"
                Text="{Binding UsedAmount, Mode=TwoWay}"
                ></Entry>

            <Button
                Text="Рассчитать себестоимость"
                Command="{Binding CalculateCostCommand}"
                HorizontalOptions="Fill" />

            <CollectionView ItemsSource="{Binding Ingredients}" HeightRequest="200" WidthRequest="320">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border
                              Margin="5"
                              Padding="10"
                              StrokeThickness="1">
                            <HorizontalStackLayout>
                                <Label Text="{Binding Name}"     
                                 Padding="10"
                                 FontSize="15"
                                 FontAttributes="Bold"
                                 HorizontalOptions="Start"
                                 />
                                <Label Text="{Binding UsedAmount}"
                                 Padding="10"
                                 FontSize="15"
                                 HorizontalOptions="Start"/>

                                <Label Text="{Binding Cost, StringFormat='Цена: {0:0.00} рублей'}"
                                 Padding="10"
                                 FontSize="15"
                                 HorizontalOptions="Start"/>

                                <Button 
                                    ImageSource="splash.png"
                                    Command="{Binding DeleteIngredientCommand}"
                                    ></Button>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
